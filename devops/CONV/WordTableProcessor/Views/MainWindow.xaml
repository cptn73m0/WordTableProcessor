<Window x:Class="WordTableProcessor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WordTableProcessor"
        xmlns:views="clr-namespace:WordTableProcessor.Views"
        mc:Ignorable="d"
        Title="Word Table Processor" Height="700" Width="1000"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E5E5"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E5E5"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D4"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F3F3F3" BorderBrush="#D1D1D1" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="16,16,16,24">
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" FontSize="28" Foreground="#0078D4"/>
                    <TextBlock Text="Word Table" FontSize="18" FontWeight="Bold" Margin="0,8,0,0" Foreground="#1A1A1A"/>
                    <TextBlock Text="Processor" FontSize="18" FontWeight="Light" Foreground="#666666"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="8,0">
                    <TextBlock Text="МЕНЮ" FontSize="11" FontWeight="SemiBold" Margin="16,0,0,10" Foreground="#666666"/>

                    <RadioButton x:Name="NavProcessor" Style="{StaticResource NavButtonStyle}"
                                 GroupName="Navigation" IsChecked="True"
                                 Checked="Navigation_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" 
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Обработка" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavCsv" Style="{StaticResource NavButtonStyle}"
                                 GroupName="Navigation"
                                 Checked="Navigation_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" 
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Генерация CSV" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavHistory" Style="{StaticResource NavButtonStyle}"
                                 GroupName="Navigation"
                                 Checked="Navigation_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" 
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="История" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <Button Grid.Row="2" x:Name="ClassicUIButton" Content="Классический интерфейс"
                        Margin="12,12" Padding="12,8"
                        HorizontalAlignment="Stretch"
                        Background="#E5E5E5" BorderBrush="#AAAAAA"
                        Click="ClassicUIButton_Click">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" 
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="White">
            <views:DocumentProcessorView x:Name="ProcessorView" Visibility="Visible"/>
            <views:CsvGeneratorView x:Name="CsvGeneratorView" Visibility="Collapsed"/>
            <views:SettingsView x:Name="HistoryView" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
