<UserControl x:Class="WordTableProcessor.Controls.FileDropZone"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="150" d:DesignWidth="500"
             AllowDrop="True"
             DragEnter="OnDragEnter"
             DragLeave="OnDragLeave"
             DragOver="OnDragOver"
             Drop="OnDrop">
    <UserControl.Resources>
        <Style x:Key="DropZoneBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F3F3F3"/>
            <Setter Property="BorderBrush" Value="#888888"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="NormalTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#666666"/>
        </Style>
    </UserControl.Resources>

    <Border x:Name="DropZoneBorder" Style="{StaticResource DropZoneBorderStyle}">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F2F2F2" Offset="0"/>
                <GradientStop Color="#E8E8E8" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="DropIcon" Text="&#xE8B7;" Style="{StaticResource IconTextStyle}"/>
            <TextBlock x:Name="DropText" Text="Перетащите файлы сюда" Style="{StaticResource NormalTextStyle}"/>
            <TextBlock x:Name="OrText" Text="или" FontSize="12" Margin="0,5,0,5" HorizontalAlignment="Center" Foreground="#999999"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="SelectWordButton" Click="SelectWordButton_Click"
                        Padding="12,6" Margin="5,0" Style="{DynamicResource ButtonStyle1}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14"/>
                                <TextBlock Text="Выбрать Word" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
                <Button x:Name="SelectCsvButton" Click="SelectCsvButton_Click"
                        Padding="12,6" Margin="5,0" Style="{DynamicResource ButtonStyle1}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14"/>
                                <TextBlock Text="Выбрать CSV" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
            <TextBlock x:Name="AllowedExtensions" Text="Поддерживаются файлы: .docx, .csv" FontSize="11"
                       HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="#999999"/>
        </StackPanel>
    </Border>
</UserControl>
